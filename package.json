{
  "name": "archiguide",
  "displayName": "ArchiGuide",
  "description": "System design assistant — from idea to project scaffold",
  "version": "0.0.1",
  "publisher": "vikhanmuhammad",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "archiguide",
          "title": "ArchiGuide",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "archiguide": [
        {
          "type": "webview",
          "id": "archiguide.sidebar",
          "name": "ArchiGuide"
        }
      ]
    },
    "commands": [
      {
        "command": "archiguide.newProject",
        "title": "ArchiGuide: New Project"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "overrides": {
    "undici": "5.28.5"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.15.0",
    "typescript": "^5.3.0"
  }
}
